

#include <iostream>
#include <fstream>
//ex1
size_t fileSize(std::ifstream& ifs) {
    size_t currPos = ifs.tellg();
    ifs.seekg(0, std::ios::end);
    size_t size = ifs.tellg();
    ifs.seekg(currPos);
    return size;
}

